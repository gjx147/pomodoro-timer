{
  "name": "pomodoro-timer",
  "version": "1.0.0",
  "description": "番茄钟桌面应用",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --dir"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "gjx147",
      "repo": "pomodoro-timer"
    },
    "directories": {
      "output": "./release"
    },
    "files": [
      "**/*",
      "!node_modules"
    ]
  }
}